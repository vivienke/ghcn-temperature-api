  "item": [
    {
      "name": "Series Tests",
      "item": [
        {
          "name": "Station Series Berlin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"status 200\", () => pm.response.to.have.status(200));\r",
                  "\r",
                  "const body = pm.response.json();\r",
                  "\r",
                  "pm.test(\"stationId matches\", () => {\r",
                  "  pm.expect(body.stationId).to.eql(pm.environment.get(\"stationIDBerlin\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"years length matches range\", () => {\r",
                  "  pm.expect(body.years.length).to.eql(body.endYear - body.startYear + 1);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"YEAR_TMIN aligned with years\", () => {\r",
                  "  pm.expect(body.series.YEAR_TMIN.length).to.eql(body.years.length);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"season series aligned with years\", () => {\r",
                  "  const body = pm.response.json();\r",
                  "  const n = body.years.length;\r",
                  "\r",
                  "  const keys = [\r",
                  "    \"YEAR_TMIN\", \"YEAR_TMAX\",\r",
                  "    \"SPRING_TMIN\", \"SPRING_TMAX\",\r",
                  "    \"SUMMER_TMIN\", \"SUMMER_TMAX\",\r",
                  "    \"AUTUMN_TMIN\", \"AUTUMN_TMAX\",\r",
                  "    \"WINTER_TMIN\", \"WINTER_TMAX\"\r",
                  "  ];\r",
                  "\r",
                  "  keys.forEach((k) => {\r",
                  "    pm.expect(body.series).to.have.property(k);\r",
                  "    pm.expect(body.series[k].length, `${k} length`).to.eql(n);\r",
                  "  });\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/stations/{{stationIDBerlin}}/series?startYear=2000&endYear=2010",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "stations",
                "{{stationIDBerlin}}",
                "series"
              ],
              "query": [
                {
                  "key": "startYear",
                  "value": "2000"
                },
                {
                  "key": "endYear",
                  "value": "2010"
                }
              ]
            },
            "description": "Generated from cURL: curl -X GET \"{{baseUrl}}/api/stations/{{stationId}}/series?startYear=&endYear=\""
          },
          "response": []
        },
