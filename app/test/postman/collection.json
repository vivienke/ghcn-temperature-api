    {
      "name": "Nearby",
      "item": [
        {
          "name": "Stations Nearby",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"status 200\", () => pm.response.to.have.status(200));\r",
                  "\r",
                  "const body = pm.response.json();\r",
                  "\r",
                  "pm.test(\"response has results array\", () => {\r",
                  "  pm.expect(body).to.have.property(\"results\");\r",
                  "  pm.expect(Array.isArray(body.results)).to.be.true;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"returns at least 1 station\", () => {\r",
                  "  pm.expect(body.results.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"first item has stationId + distanceKm\", () => {\r",
                  "  const first = body.results[0];\r",
                  "  pm.expect(first).to.have.property(\"stationId\");\r",
                  "  pm.expect(first).to.have.property(\"distanceKm\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"availability has firstYear/lastYear\", () => {\r",
                  "  const first = body.results[0];\r",
                  "  pm.expect(first).to.have.property(\"availability\");\r",
                  "  pm.expect(first.availability).to.have.property(\"firstYear\");\r",
                  "  pm.expect(first.availability).to.have.property(\"lastYear\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/stations/nearby?lat=48.0623&lon=8.4936&radiusKm=50&limit=5&startYear=2005&endYear=2015",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "stations",
                "nearby"
              ],
              "query": [
                {
                  "key": "lat",
                  "value": "48.0623"
                },
                {
                  "key": "lon",
                  "value": "8.4936"
                },
                {
                  "key": "radiusKm",
                  "value": "50"
                },
                {
                  "key": "limit",
                  "value": "5"
                },
                {
                  "key": "startYear",
                  "value": "2005"
